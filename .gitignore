# ─────────────────────────────────────────────────────────────
#  Angler BI — .gitignore
#  This repo contains only what GitHub Pages needs to serve
#  the site. All tooling, automation, and pipelines are local.
# ─────────────────────────────────────────────────────────────


# ── SECRETS ───────────────────────────────────────────────────
.env
.env.local
.env.*.local


# ── LOCAL TOOLING & AUTOMATION ────────────────────────────────
# Content pipeline — runs locally only
blog-pipeline/

# Automation skills — local only
skills/

# Local site info — not part of GitHub Pages deploy
anglerbi-info/

# Editor/IDE workspace state
.claude/
.vscode/
.idea/


# ── DEPENDENCIES ──────────────────────────────────────────────
node_modules/


# ── ARTICLE INTERNALS ─────────────────────────────────────────
# Only the rendered HTML and images go to GitHub Pages
blog/articles/*/article.md
blog/articles/*/publish-kit.md


# ── OS ARTIFACTS ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini
*.swp
*.swo
*~


# ── PLAYWRIGHT ────────────────────────────────────────────────
.playwright-cli/
